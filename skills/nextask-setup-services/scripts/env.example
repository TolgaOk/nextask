DB_PASSWORD=<generate-a-strong-password>

# Port overrides (uncomment if defaults 5432/3000 conflict with local services)
# NEXTASK_PG_PORT=5433
# NEXTASK_GITEA_PORT=3001

# After 'docker compose up -d', get these values:
#   DB URL:  postgres://nextask:<DB_PASSWORD>@<HOST>:<NEXTASK_PG_PORT>/nextask
#   Remote:  docker compose logs gitea-init  (prints the full URL with token)
